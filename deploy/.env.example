# Copy to .env and fill in LLM key(s). See deploy/README.md.

ADVISER_IMAGE_TAG=local
COMPOSE_PROFILES=local

ADVISER_HOST_DATA_DIR=./.data
ADVISER_HOST_LOG_DIR=./.data/logs

# Required on first start when system.db has no accounts (creates admin)
ADMIN_PASSWORD=changeme

# Required when config/llm.yaml references ${NVIDIA_API_KEY} or ${OPENAI_API_KEY}
NVIDIA_API_KEY=
OPENAI_API_KEY=
