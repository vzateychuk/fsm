{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run main",
      "type": "debugpy",
      "request": "launch",
      "module": "main.main",
      "args": ["LOG_FILE", "${workspaceFolder}/logs/ingest.log"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
  ]
}